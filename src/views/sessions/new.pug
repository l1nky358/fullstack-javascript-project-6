extends ../layout

block content
  .row.justify-content-center
    .col-md-6
      h1.mb-4 Вход

      form(action='/session' method='POST')
        .mb-3
          label.form-label(for='data_email') Email
          input.form-control(type='email' id='data_email' name='data[email]' class=(flash && flash.error && flash.error.includes('email') ? 'is-invalid' : '') required)
          if flash && flash.error && flash.error.includes('Неправильный')
            .invalid-feedback(style='display: block')
              = flash.error
          else if flash && flash.error && flash.error.includes('email')
            .invalid-feedback(style='display: block')
              = flash.error
        
        .mb-3
          label.form-label(for='data_password') Пароль
          input.form-control(type='password' id='data_password' name='data[password]' class=(flash && flash.error && flash.error.includes('пароль') ? 'is-invalid' : '') required)
          if flash && flash.error && (flash.error.includes('пароль') || flash.error.includes('Пароль'))
            .invalid-feedback(style='display: block')
              = flash.error
        
        .mb-3
          button.btn.btn-primary(type='submit') Войти
          a.btn.btn-secondary.ms-2(href='/') Отмена
