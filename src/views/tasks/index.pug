extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Задачи
    if user
      a.btn.btn-primary(href='/tasks/new') Создать задачу

  // Форма фильтрации
  .card.mb-4
    .card-body
      form(method='GET' action='/tasks')
        .row.align-items-end
          // Фильтр по статусу
          .col-md-3.mb-3
            label.form-label(for='data_status') Статус
            select.form-select(id='data_status' name='status')
              option(value='') Все статусы
              if statuses && statuses.length > 0
                each status in statuses
                  option(value=status.id selected=(filters && Number(filters.status) === status.id))= status.name
          
          // Фильтр по исполнителю
          .col-md-3.mb-3
            label.form-label(for='data_assigned_to_id') Исполнитель
            select.form-select(id='data_assigned_to_id' name='assigned_to_id')
              option(value='') Все исполнители
              if users && users.length > 0
                each userItem in users
                  option(value=userItem.id selected=(filters && Number(filters.assigned_to_id) === userItem.id))= `${userItem.firstName} ${userItem.lastName}`
          
          // Фильтр по метке - ВАЖНО: id='data_label', name='label'
          .col-md-2.mb-3
            label.form-label(for='data_label') Метка
            select.form-select(id='data_label' name='label')
              option(value='') Все метки
              if labels && labels.length > 0
                each label in labels
                  option(value=label.id selected=(filters && Number(filters.label) === label.id))= label.name
          
          // Чекбокс "Только мои задачи"
          .col-md-2.mb-3
            .form-check.mt-4
              input.form-check-input(type='checkbox' id='data_my_tasks' name='isCreatorUser' checked=(filters && filters.isCreatorUser === 'on'))
              label.form-check-label(for='data_my_tasks') Только мои задачи
          
          .col-md-2.mb-3
            button.btn.btn-primary.w-100.mt-4(type='submit') Показать
            a.btn.btn-secondary.w-100.mt-2(href='/tasks') Сбросить

  // Таблица с задачами
  if tasks && tasks.length > 0
    .table-responsive
      table.table.table-striped
        thead
          tr
            th ID
            th Название
            th Статус
            th Автор
            th Исполнитель
            th Метки
            if user
              th Действия
        tbody
          each task in tasks
            tr
              td= task.id
              td
                a(href=`/tasks/${task.id}`)= task.name
              td= task.status ? task.status.name : '-'
              td= task.creator ? `${task.creator.firstName} ${task.creator.lastName}` : '-'
              td= task.executor ? `${task.executor.firstName} ${task.executor.lastName}` : 'Не назначен'
              td
                if task.labels && task.labels.length > 0
                  each label in task.labels
                    span.badge.bg-secondary.me-1= label.name
                else
                  span.text-muted —
              if user && user.id === task.creatorId
                td
                  a.btn.btn-sm.btn-primary(href=`/tasks/${task.id}/edit`) Изменить
                  form.d-inline(action=`/tasks/${task.id}/delete` method='POST' onsubmit='return confirm("Вы уверены?")')
                    button.btn.btn-sm.btn-danger.ms-2(type='submit') Удалить
  else
    p.text-muted Задачи отсутствуют
