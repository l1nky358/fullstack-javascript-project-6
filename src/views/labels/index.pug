extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Метки
    if user
      a.btn.btn-primary(href='/labels/new') Создать метку

  if flash && flash.success
    .alert.alert-success.alert-dismissible.fade-show(role='alert')
      = flash.success
      button.btn-close(type='button' data-bs-dismiss='alert')
  
  if flash && flash.error
    .alert.alert-danger.alert-dismissible.fade-show(role='alert')
      = flash.error
      button.btn-close(type='button' data-bs-dismiss='alert')

  if labels && labels.length > 0
    table.table.table-striped
      thead
        tr
          th ID
          th Название
          if user
            th Действия
      tbody
        each label in labels
          tr
            td= label.id
            td= label.name
            if user
              td
                a.btn.btn-sm.btn-primary(href=`/labels/${label.id}/edit`) Редактировать
                form.d-inline(action=`/labels/${label.id}?_method=DELETE` method='POST')
                  input(type='hidden' name='_method' value='DELETE')
                  button.btn.btn-sm.btn-danger.ms-2(type='submit' onclick='return confirm("Вы уверены?")') Удалить
  else
    p.text-muted Метки отсутствуют