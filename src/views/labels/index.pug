extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Метки
    if user
      a.btn.btn-primary(href='/labels/new') Создать метку

  if labels && labels.length > 0
    table.table.table-striped
      thead
        tr
          th ID
          th Наименование
          if user
            th Действия
      tbody
        each label in labels
          tr
            td= label.id
            td= label.name
            if user
              td
                a.btn.btn-sm.btn-primary(href=`/labels/${label.id}/edit`) Изменить
                form.d-inline(action=`/labels/${label.id}/delete` method='POST')
                  button.btn.btn-sm.btn-danger.ms-2(type='submit' onclick='return confirm("Вы уверены?")') Удалить
  else
    p.text-muted Метки отсутствуют
