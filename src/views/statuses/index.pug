extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h1 Статусы задач
    if user
      a.btn.btn-primary(href='/statuses/new') Создать статус

  if statuses && statuses.length > 0
    table.table.table-striped
      thead
        tr
          th ID
          th Наименование
          if user
            th Действия
      tbody
        each status in statuses
          tr
            td= status.id
            td= status.name
            if user
              td
                a.btn.btn-sm.btn-primary(href=`/statuses/${status.id}/edit`) Изменить
                form.d-inline(action=`/statuses/${status.id}/delete` method='POST')
                  button.btn.btn-sm.btn-danger.ms-2(type='submit' onclick='return confirm("Вы уверены?")') Удалить
  else
    p.text-muted Статусы отсутствуют
