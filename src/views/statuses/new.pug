extends ../layout

block content
  h1.mb-4 Создание статуса

  if flash && flash.error
    .alert.alert-danger.alert-dismissible.fade-show(role='alert')
      = flash.error
      button.btn-close(type='button' data-bs-dismiss='alert')

  form(action='/statuses' method='POST')
    .mb-3
      label.form-label(for='data_name') Наименование
      input.form-control(type='text' id='data_name' name='data[name]' value=(status ? status.name : '') required)
    
    .mb-3
      button.btn.btn-primary(type='submit') Создать
      a.btn.btn-secondary.ms-2(href='/statuses') Отмена
