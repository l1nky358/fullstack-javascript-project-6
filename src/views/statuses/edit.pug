extends ../layout

block content
  h1.mb-4 Редактирование статуса

  if flash.error
    .alert.alert-danger.alert-dismissible.fade-show(role='alert')
      = flash.error
      button.btn-close(type='button' data-bs-dismiss='alert')

  form(action=`/statuses/${status.id}?_method=PATCH` method='POST')
    input(type='hidden' name='_method' value='PATCH')
    
    .mb-3
      label.form-label(for='data_name') Название
      input.form-control(type='text' id='data_name' name='data[name]' value=status.name required)
    
    .mb-3
      button.btn.btn-primary(type='submit') Обновить
      a.btn.btn-secondary.ms-2(href='/statuses') Отмена