extends ../layout

block content
  .row.justify-content-center
    .col-md-6
      h1.mb-4 Регистрация

      if flash && flash.error
        .alert.alert-danger.alert-dismissible.fade-show(role='alert')
          = flash.error
          button.btn-close(type='button' data-bs-dismiss='alert')

      form(action='/users' method='POST')
        .mb-3
          label.form-label(for='data_firstName') Имя
          input.form-control(type='text' id='data_firstName' name='data[firstName]' value=(user ? user.firstName : '') required)
        
        .mb-3
          label.form-label(for='data_lastName') Фамилия
          input.form-control(type='text' id='data_lastName' name='data[lastName]' value=(user ? user.lastName : '') required)
        
        .mb-3
          label.form-label(for='data_email') Email
          input.form-control(type='email' id='data_email' name='data[email]' value=(user ? user.email : '') required)
        
        .mb-3
          label.form-label(for='data_password') Пароль
          input.form-control(type='password' id='data_password' name='data[password]' required)
        
        .mb-3
          button.btn.btn-primary(type='submit') Зарегистрироваться
          a.btn.btn-secondary.ms-2(href='/') Отмена