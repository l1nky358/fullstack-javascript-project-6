doctype html
html(lang='ru')
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title #{title} | Task Manager
    
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css' rel='stylesheet')
    
  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container
        a.navbar-brand(href='/') Task Manager
        button.navbar-toggler(type='button' data-bs-toggle='collapse' data-bs-target='#navbarNav')
          span.navbar-toggler-icon
        .collapse.navbar-collapse(id='navbarNav')
          ul.navbar-nav.ms-auto
            li.nav-item
              a.nav-link(href='/') Главная
            li.nav-item
              a.nav-link(href='/tasks') Задачи
            li.nav-item
              a.nav-link(href='/statuses') Статусы
            li.nav-item
              a.nav-link(href='/labels') Метки
            li.nav-item
              a.nav-link(href='/users') Пользователи
            if user
              li.nav-item
                form(action='/session/delete' method='POST')
                  button.btn.btn-link.nav-link(type='submit') Выход
            else
              li.nav-item
                a.nav-link(href='/session/new') Вход
              li.nav-item
                a.nav-link(href='/users/new') Регистрация

    main.container.mt-4
      // УДАЛИТЕ ЭТОТ БЛОК - flash сообщения будут в дочерних шаблонах
      block content

    footer.bg-light.text-center.text-muted.py-3.mt-5
      .container
        p.mb-0 &copy; #{currentYear} Task Manager. All rights reserved.

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js')
